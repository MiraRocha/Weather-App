<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/azulEscuro"
    android:orientation="vertical"
    android:padding="20dp"
    tools:context=".Views.MainLoginActivity">

    <!-- FOTO E BOTÕES PERFIL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imgFotoProfile"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginEnd="16dp"
            android:background="#DDDDDD"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_camera" />

        <!-- CONTAINER PARA OS BOTÕES LADO A LADO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp">

            <!-- BOTÃO PERFIL -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPerfil"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="PERFIL"
                android:textColor="@color/white"
                app:backgroundTint="@color/verde"
                app:cornerRadius="10dp"
                android:textSize="14sp"
                android:textStyle="bold"
                app:rippleColor="@color/verdeEscuro"
                android:elevation="4dp"
                app:strokeColor="@color/verde"
                app:strokeWidth="0dp"/>

            <!-- BOTÃO SAIR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSair"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="SAIR"
                android:textColor="@color/white"
                app:backgroundTint="@color/verde"
                app:cornerRadius="10dp"
                android:textSize="14sp"
                android:textStyle="bold"
                app:rippleColor="@color/verdeEscuro"
                android:elevation="4dp"
                app:strokeColor="@color/verde"
                app:strokeWidth="0dp"/>

        </LinearLayout>

    </LinearLayout>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/animationView"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        app:lottie_rawRes="@raw/weatherlottie"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"/>

    <!-- BOTÃO VOLTAR CIDADE ATUALIZADO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVoltarCidade"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:text="Pesquisar novamente"
        android:textColor="@color/white"
        app:backgroundTint="#95cf5b"
        app:cornerRadius="10dp"
        android:textSize="14sp"
        android:textStyle="bold"
        app:rippleColor="#7CB342"
        android:elevation="4dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"/>

    <!-- SECÇÃO DO CLIMA -->
    <TextView
        android:id="@+id/txtCidadesPesquisadas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="30dp"
        android:text="📍 Últimas cidades pesquisadas"
        android:textColor="@color/verde"
        android:textSize="20sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewCidades"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1" />

</LinearLayout>